{
  "name": "task-manager-backend",
  "version": "1.0.0",
  "description": "Task Manager Backend built with Express, Prisma, JWT, and Socket.io",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "prisma generate && prisma db push --force-reset && tsc",
    "start": "node dist/server.js",
    "test": "jest"
  },
  "keywords": [
    "express",
    "typescript",
    "prisma",
    "postgresql",
    "jwt",
    "socket.io",
    "backend",
    "task-manager"
  ],
  "author": "Vaibhav",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.19.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^4.2.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/socket.io-client": "^1.4.36",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
